<UserControl
    x:Class="RecordClient.Views.Controls.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:oxy="http://oxyplot.org/wpf"
    xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:conv="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
    xmlns:myConv="clr-namespace:RecordClient.Helpers.Converters"
    mc:Ignorable="av"
    Width="375"
    Height="Auto"
    BorderThickness="0"
    BorderBrush="Transparent"
    Background="Transparent"
    Cursor="Arrow"
    FontSize="12"
    Loaded="MainPage_Loaded"
    Unloaded="MainPage_Unloaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <myConv:VolumeToWidthConverter x:Key="VolumeToWidthConverter" MaxWidth="100"/>
        <myConv:BoolInverseConverter x:Key="BoolInverseConverter"/>
        <Storyboard x:Key="BlinkStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetName="BlinkIcon"
                Storyboard.TargetProperty="Opacity"
                From="1" To="0"
                Duration="0:0:0.5" 
                AutoReverse="True" />
        </Storyboard>

        <!-- 열기 이벤트 (Height: 0 → 70) -->
        <Storyboard x:Key="SubAreaOpenStoryboard_0">
            <DoubleAnimation Storyboard.TargetName="SubArea"
                     Storyboard.TargetProperty="Height"
                     To="70" Duration="0:0:0.5"
                     FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <!-- 열기 이벤트 (Height: 0 → 160) -->
        <Storyboard x:Key="SubAreaOpenStoryboard_1">
            <DoubleAnimation Storyboard.TargetName="SubArea"
             Storyboard.TargetProperty="Height"
             To="160" Duration="0:0:0.5"
             FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- 닫기 이벤트 (Height:  → 0) -->
        <Storyboard x:Key="SubAreaCloseStoryboard">
            <DoubleAnimation Storyboard.TargetName="SubArea"
                     Storyboard.TargetProperty="Height"
                     To="0" Duration="0:0:0.5"
                     FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="MainContainer" Cursor="Arrow">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="Body" Cursor="Hand">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>


            <!-- 파형 UI 영역(현재 미사용) -->
            <Grid x:Name="WaveArea" Grid.Row="0" Cursor="Arrow" Background="#FF1A1A1E">
                <!--
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="5,5,5,0">
                    <StackPanel Cursor="Arrow">
                            <oxy:PlotView x:Name="WavePlot" Model="{Binding WaveModel}" Background="#FF1A1A1E" Cursor="Arrow" Height="57">
                                <oxy:PlotView.Clip>
                                    <RectangleGeometry RadiusX="6" RadiusY="6" Rect="0,0,605,114"/>
                                </oxy:PlotView.Clip>
                            </oxy:PlotView>
                        </Border>
                    </StackPanel>
                </Border>
                 -->
            </Grid>

            <!-- 컨트롤 버튼 UI 영역 -->
            <Grid x:Name="MainArea" Grid.Row="1" Cursor="Arrow" Background="#FF1A1A1E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="5,5,5,5">
                    <Grid>
                        <Border HorizontalAlignment="Left" CornerRadius="3,3,3,3" Background="#FF2F2F2F" Height="28" Width="100">
                            <StackPanel HorizontalAlignment="Center" Width="100" Orientation="Horizontal">
                                <Border Background="#FF944B3A" Width="16" Height="16" Panel.ZIndex="99" CornerRadius="10,10,10,10" Cursor="Arrow" Margin="5,0,0,0" >
                                    <Ellipse x:Name="BlinkIcon" Width="16" Height="16" Fill="#FFFF6F61" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Arrow"/>

                                </Border>
                                <TextBlock x:Name="TimerText" Text="{Binding TimerText}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Noto Sans KR" FontWeight="Bold" Margin="13,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <StackPanel HorizontalAlignment="Center" Cursor="Hand" VerticalAlignment="Center">
                            <ToggleButton Width="65" Height="28" x:Name="RecordButton"
                                IsChecked="{Binding IsRecording, Mode=OneWay}" Command="{Binding ToggleRecordCommand}">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton" BasedOn="{StaticResource RedButtonStyleToggle}"></Style>
                                </ToggleButton.Style>

                                <Image x:Name="RecordButtonImage"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Width="24" Height="24"
                                   Stretch="Fill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Source="{Binding RecordIconPath}">
                                </Image>
                            </ToggleButton>

                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Cursor="Arrow" HorizontalAlignment="Right" >
                            <Button Command="{Binding ToggleTabCommand}" CommandParameter="1"
                                    x:Name="ToggleCommentButton"
                                    Style="{StaticResource ButtonStyle}"
                                    Width="30" Height="28" Background="#FF2F2F2F" Cursor="Hand">
                                <Image x:Name="ToggleCommentButtonImage"
                                        Source="{Binding ChatIconPath}" 
                                        Width="30" Height="28" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <ToggleButton x:Name="MicMuteToggle" 
                                Style="{StaticResource ButtonStyleToggle}"
                                HorizontalAlignment="Center"
                                Width="30" 
                                Command="{Binding ToggleInputMuteCommand}"
                                Background="#FF2F2F2F" 
                                Margin="5,0,0,0" 
                                Height="28" 
                                Cursor="Hand">
                                <Image x:Name="MicMuteButtonImage"
                                    Source="{Binding MicIconPath}"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Height="16"
                                    Width="18"/>
                            </ToggleButton>

                            <ToggleButton x:Name="SpeakerMuteToggle"
                                Style="{StaticResource ButtonStyleToggle}"
                                Width="30" Height="28"
                                Background="#FF2F2F2F"
                                Cursor="Hand"
                                Margin="5,0,5,0"
                                Command="{Binding ToggleOutputMuteCommand}">
                                <Image x:Name="SpkMuteButtonImage"
                                    Source="{Binding SpeakerIconPath}"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Height="16"
                                    Width="18"/>
                            </ToggleButton>

                            <Button Command="{Binding ToggleTabCommand}" CommandParameter="0"
                                    x:Name="ToggleWindowButton"
                                    Style="{StaticResource ButtonStyle}"
                                    Width="30" Height="28" Background="#FF2F2F2F" Cursor="Hand">
                                <Image x:Name="ToggleWindowButtonImage"
                                        Source="{Binding SettingIconPath}" 
                                        Width="16" Height="16" Cursor="Hand"/>
                            </Button>
                        </StackPanel>

                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" x:Name="SubArea" Cursor="Arrow" Visibility="Visible" Background="#222326" VerticalAlignment="Top" Height="0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="Adjustment" Grid.Row="0" Padding="5,0,5,0" Cursor="Arrow"
                        Visibility="{Binding IsAdjustmentVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid Cursor="Arrow">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,21,0" VerticalAlignment="Top">
                            <Grid Cursor="Arrow">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Label Grid.Column="0" Style="{StaticResource LabelStyle}" Content="기본 녹음 장치" FontSize="11"  Height="25" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <!-- <Button Grid.Column="1" Style="{StaticResource ButtonStyle}" 
                                        Width="20" Height="25" 
                                        VerticalAlignment="Center" HorizontalAlignment="Center" 
                                        Background="{x:Null}" BorderBrush="{x:Null}" 
                                        Cursor="Hand"
                                        Command="{Binding ToggleInputMonitoring}">
                                    <Image x:Name="InputSpeaker" Source="/Resources/Images/mic_white.png" 
                                           RenderOptions.BitmapScalingMode="HighQuality" 
                                           Width="13" Height="13" 
                                           Margin="0,2,0,0" Cursor="Hand"/>
                                </Button>-->

                            </Grid>
                            <!-- 입력 장치 선택 콤보박스 -->
                            <ComboBox x:Name="InputDeviceComboBox"
                                      Style="{StaticResource HoverComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                                      ItemsSource="{Binding InputDeviceList}"
                                      SelectedItem="{Binding SelectedInputDevice, Mode=TwoWay}"
                                      IsEnabled="{Binding IsRecording, Converter={StaticResource BoolInverseConverter}}"
                                      SelectionChanged="InputDeviceComboBox_SelectionChanged"
                                      DisplayMemberPath="Name"
                                      IsSynchronizedWithCurrentItem="True"
                                      VerticalAlignment="Center"
                                      BorderBrush="{x:Null}"
                                      Height="20"
                                      Background="#FF2F2F2F"
                                      Foreground="White"
                                      FontSize="10"
                                      Cursor="Arrow"
                                      Margin="0,0,0,3" 
                                      PreviewMouseDown="ComboBox_PreviewButtonDown"
                                      />
                            <!-- SelectionChanged="InputDeviceComboBox_SelectionChanged" -->
                            <!-- 입력 볼륨 조절 슬라이더 + 게이지 바 -->
                            <!--Value="{Binding InputVolume, Mode=TwoWay}"-->
                            <Grid>
                                <Slider x:Name="InputLevelSlider"
                                    Style="{StaticResource RoundSliderStyle}"
                                    Height="15"
                                    Cursor="Hand"
                                    Minimum="0"
                                    Maximum="1"
                                    SmallChange="0.01"
                                    Value="{Binding InputVolume, Mode=TwoWay}"
                                    IsEnabled="{Binding IsInputMuted, Converter={StaticResource BoolInverseConverter}}"
                                    PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                    PreviewMouseDown="Slider_PreviewMouseLeftButtonDown"
                                    ValueChanged="Slider_ValueChanged"/>

                                <Rectangle x:Name="InputVolumeBar"
                                    HorizontalAlignment="Left"
                                    Fill="White"
                                    Width="0"
                                    Height="3"
                                    VerticalAlignment="Center"/>
                            </Grid>

                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" Cursor="Arrow">
                            <Grid Cursor="Arrow">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Label Grid.Column="0" Style="{StaticResource LabelStyle}" Content="기본 출력 장치" FontSize="11" Height="25" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Button Grid.Column="1" Style="{StaticResource ButtonStyle}" 
                                        Width="20" Height="25" 
                                        VerticalAlignment="Center" HorizontalAlignment="Center" 
                                        Background="{x:Null}" BorderBrush="{x:Null}" Cursor="Hand"
                                        Click="Output_Button_Click">
                                    <Image x:Name="OutputSpeaker" Source="/Resources/Images/speaker_white.png" RenderOptions.BitmapScalingMode="HighQuality" Width="12" Height="12" Margin="0,2,0,0" Cursor="Hand"/>
                                </Button>

                                <!-- <Controls:ToggleSwitch Grid.Column="2" x:Name="VolumeMonitorToggle" Toggled="VolumeMonitorToggle_Toggled" Height="27" Width="Auto" HorizontalAlignment="Right" Margin="14,-5,0,0" /> -->
                            </Grid>
                            <ComboBox x:Name="OutputDeviceComboBox"
                                Style="{StaticResource HoverComboBoxStyle}"
                                ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                                ItemsSource="{Binding OutputDeviceList}"
                                SelectedItem="{Binding SelectedOutputDevice}"
                                IsEnabled="{Binding IsRecording, Converter={StaticResource BoolInverseConverter}}"
                                SelectionChanged="OutputDeviceComboBox_SelectionChanged"
                                IsSynchronizedWithCurrentItem="True"
                                DisplayMemberPath="Name"
                                VerticalAlignment="Center"
                                BorderBrush="{x:Null}"
                                Height="20"
                                Background="#FF2F2F2F"
                                Foreground="White"
                                FontSize="10"
                                Cursor="Arrow"
                                Margin="0,0,0,3"
                                PreviewMouseDown="ComboBox_PreviewButtonDown"
                                />
                            <Grid>
                                <Slider x:Name="OutputLevelSlider"
                                    Style="{StaticResource RoundSliderStyle}"
                                    Minimum="0" Maximum="1"
                                    SmallChange="0.01"
                                    Value="{Binding OutputVolume, Mode=TwoWay}"
                                    Height="15" Cursor="Hand"
                                    IsEnabled="{Binding IsOutputMuted, Converter={StaticResource BoolInverseConverter}}"
                                    PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                    PreviewMouseDown="Slider_PreviewMouseLeftButtonDown"
                                    ValueChanged="Slider_ValueChanged"/>

                                <Rectangle x:Name="OutputVolumeBar"
                                    HorizontalAlignment="Left"
                                    Fill="White"
                                    Width="0"
                                    Height="3"
                                    VerticalAlignment="Center"
                                    />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid x:Name="CommentField" Grid.Row="1"
                      Visibility="{Binding IsCommentVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ScrollViewer x:Name="CommentViewer" Grid.Row="0" VerticalScrollBarVisibility="Auto" FontFamily="Noto Sans KR">
                        <ItemsControl x:Name="CommentList" ItemsSource="{Binding CommentMessages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="5,2" Background="#22FFFFFF" Padding="5" CornerRadius="4">
                                        <TextBlock Text="{Binding Display}"
                                           Foreground="White"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </ScrollViewer>
                    <StackPanel x:Name="CommentEditor" Grid.Row="1">
                        <Grid Height="40" >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" MinWidth="46"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="White" CornerRadius="2" Margin="5,5,0,5">
                                <TextBox x:Name="InputBox"
                                     Text="{Binding InputCommentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FocusVisualStyle="{x:Null}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     PreviewKeyDown="InputBox_KeyDown"
                                     Padding="4"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="26"
                                     MaxHeight="100"
                                     FontSize="11" FontFamily="Noto Sans KR"
                                     />
                            </Border>
                            <Button x:Name="Commit" Grid.Column="1" 
                                    Style="{StaticResource RedButtonStyle}" 
                                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                    Cursor="" Padding="1,1,1,1" Margin="5,5,5,5" 
                                    Click="EnterButton_Click">
                                <Image x:Name="Enter_Button"
                                   Source="/Resources/Images/enter_white.png"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Stretch="Fill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsEnabled="False" Cursor="Arrow"
                                  />
                            </Button>
                        </Grid>

                    </StackPanel>
                </Grid>

            </Grid>



        </Grid>

        <!-- <Controls:RangeSlider HorizontalAlignment="Left" Margin="822,281,0,0" Grid.Row="4" Height="24" Width="0"/> -->

    </Grid>
</UserControl>