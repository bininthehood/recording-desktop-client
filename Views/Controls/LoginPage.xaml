<UserControl x:Class="RecordClient.Views.Controls.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    mc:Ignorable="d" 
    
    Width="375"
    Height="Auto">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Style/StyleCommon.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="LoginContainer" Background="#FF1A1A1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel HorizontalAlignment="Center" Grid.Row="0" Width="105" Margin="0,10,0,10">
            <Image Source="/Resources/Images/logo.ico" Height="76" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel HorizontalAlignment="Center" Grid.Row="1" Width="200" Margin="0,10,0,30">
            <Grid Height="Auto">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <TextBox Style="{StaticResource TextBoxCommonStyle}" Grid.Column="0" x:Name="ServerIpTextBox" Width="140" mah:TextBoxHelper.Watermark="Host"  HorizontalAlignment="Left" TextChanged="ServerIpTextBox_TextChanged" Text=""/>
                <TextBox Style="{StaticResource TextBoxCommonStyle}" Grid.Column="1" x:Name="ServerPortTextBox" Width="60" mah:TextBoxHelper.Watermark="Port" HorizontalAlignment="Right" TextChanged="ServerPortTextBox_TextChanged" Text=""/>
            </Grid>

            <TextBox Style="{StaticResource TextBoxCommonStyle}" x:Name="UserIdTextBox" Width="200" Margin="0,7,0,0" mah:TextBoxHelper.Watermark="아이디를 입력하세요."/>

            <PasswordBox Style="{StaticResource PasswordBoxCommonStyle}" x:Name="PasswordBox" Width="200" Margin="0,7,0,0" mah:TextBoxHelper.Watermark="비밀번호를 입력하세요." Password=""/>

            <Button Style="{StaticResource ButtonCommonStyle}" x:Name="LoginButton" Width="200" Margin="0,7,0,0" Click="LoginButton_Click">
                <Grid>
                    <!-- 로그인 텍스트 -->
                    <TextBlock x:Name="LoginButtonText"
                        Text="LOGIN"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Visible"/>

                    <!-- 로딩 ProgressRing -->
                    <mah:ProgressRing x:Name="LoginButtonRing"
                        Width="20"
                        IsActive="False"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" Height="20"/>
                </Grid>
            </Button>
        </StackPanel>

    </Grid>
</UserControl>
