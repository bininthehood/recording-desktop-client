<Controls:MetroWindow x:Class="RecordClient.Views.Controls.Modules.ConfirmDialog"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="" FontSize="12" MaxHeight="200" MinHeight="160" Height="Auto" Width="300" TitleCharacterCasing="Lower" 
                      FontFamily="Noto Sans KR"
                      WindowStartupLocation="CenterOwner"
                      ResizeMode="NoResize"
                      ShowInTaskbar="False"
                      WindowTitleBrush="#FF101014"
                      GlowBrush="Transparent">

    <Grid Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="MessageText"
                   TextWrapping="Wrap"
                   FontSize="16"
                   Grid.Row="0"
                   Margin="0,0,0,20"
                   TextAlignment="Center"
                   Foreground="{DynamicResource MahApps.Brushes.Text}"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" >
            <Button Content="확인" Width="100" Margin="10,0" IsDefault="True" Click="Confirm_Click"/>
            <Button Content="취소" Width="100" Margin="10,0" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Controls:MetroWindow>
