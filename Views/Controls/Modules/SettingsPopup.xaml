<UserControl x:Class="RecordClient.Views.Controls.Modules.SettingsPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
             Width="375" Height="Auto"
             Loaded="SettingPage_Loaded"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Style/StyleCommon.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <!-- #FF101014 -->
    <Border Background="#FF101014"
            Padding="20,20,20,10"
            BorderThickness="0" Margin="0,0,0,0">
        
        <Border.Effect>
            <DropShadowEffect Color="Black"
                BlurRadius="0"
                ShadowDepth="4"
                Opacity="0.4" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Text="설정" Foreground="#FFFFFF" FontSize="18" FontWeight="Bold" HorizontalAlignment="Left" Grid.Column="0"/>
                <Button Content="X" Grid.Column="1" Foreground="#FFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="0" FontSize="18" Height="25" Width="25" Background="{x:Null}" BorderBrush="{x:Null}" Click="Button_Click"/>
            </Grid>
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="웹 연동 여부" Foreground="#FFFFFF" />
                    <TextBlock Text="( 웹 연동 모드에서는 호스트 엔진을 직접 제어할 수 없습니다. )" Foreground="#FFFFFF" FontSize="11" Margin="0 5"/>

                    <ToggleButton x:Name="ClientModeWeb" Grid.Column="2"
                          Content="미사용"
                          Padding="0"
                          Width="80" Height="30" Margin="0 10"
                          HorizontalAlignment="Left"
                          Background="Gray"
                          Foreground="White"
                          FontWeight="Bold"
                          BorderThickness="0"
                          BorderBrush="Transparent"
                          Checked="ClientMode_On"
                          Unchecked="ClientMode_Off" />

                    <TextBlock Text="엔진 서버 IP" Foreground="#FFFFFF"  Margin="0 5" />
                    <TextBox Style="{StaticResource TextBoxCommonStyle}" x:Name="ServerIpTextBox" Width="Auto" Margin="0 5" />

                    <TextBlock Text="엔진 서버 포트" Foreground="#FFFFFF" Margin="0 5" />
                    <TextBox Style="{StaticResource TextBoxCommonStyle}" x:Name="ServerPortTextBox" Width="Auto" Margin="0 5" />

                    <TextBlock Text="로컬 파일 저장 경로" Foreground="#FFFFFF" Margin="0 5" />
                    <TextBlock Text="(기본값 : C:/VoiceLog/LocalData/Rec/)" Foreground="#FFFFFF" FontSize="11" Margin="0 5"/>
                    <TextBox Style="{StaticResource TextBoxCommonStyle}" x:Name="ServerPathTextBox" Width="Auto" Margin="0 5" />

                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                <Button x:Name="SaveButton" Style="{StaticResource ButtonCommonStyle}" Content="확인" Width="80" Click="SaveServerSettings_Click" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
