<UserControl x:Class="RecordClient.Views.Controls.Modules.ToastNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RecordClient.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="400"
             RenderTransformOrigin="0.5,0.5">
    <UserControl.RenderTransform>
        <TranslateTransform />
    </UserControl.RenderTransform>

    <Border Background="DarkGray" CornerRadius="6" MinHeight="24"
            Margin="20,0,20,5" Padding="15,0,20,1"
            VerticalAlignment="Center"
            IsHitTestVisible="False">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" IsHitTestVisible="False">
            <Image Source="{Binding IconSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Margin="0,2,5,0" Height="16"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                SnapsToDevicePixels="True" Width="16"/>
            <TextBlock Text="{Binding Message, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Foreground="White"
                FontFamily="Noto Sans KR" TextWrapping="Wrap"
                TextAlignment="Left"
                MaxWidth="250"
                xml:space="preserve"
                VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
